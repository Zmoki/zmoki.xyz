---
export interface Props {
  brevoFormId: string;
  buttonText?: string;
}

const defaultButtonText = "Subscribe";
const { brevoFormId, buttonText = defaultButtonText } = Astro.props;
---

<!-- Main form -->
<form
  id="brevo-form"
  method="POST"
  action={`https://${import.meta.env.PUBLIC_BREVO_ACCOUNT_ID}.sibforms.com/serve/${brevoFormId}`}
  class="flex flex-col gap-4 rounded-xl bg-zmoki-surface px-4 py-8 shadow-md md:flex-row md:gap-8 md:p-8 xl:gap-12 xl:p-12"
>
  <section class="prose prose-lg !leading-tight xl:prose-2xl prose-headings:font-semibold md:w-1/2">
    <slot />
  </section>

  <section class="flex min-w-[300px] flex-1 flex-col gap-4 md:pt-2">
    <!-- Email input -->
    <label for="EMAIL" class="font-mono text-xl font-medium">Email</label>
    <input
      type="email"
      id="EMAIL"
      name="EMAIL"
      placeholder="your@email.com"
      required
      class="w-full rounded-sm border border-slate-300 p-2 font-mono text-lg"
    />

    <!-- Captcha -->
    <div
      class="cf-turnstile g-recaptcha"
      data-sitekey={import.meta.env.PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY}
      data-size="flexible"
      data-language="en"
    >
    </div>

    <!-- Legal consent checkbox -->
    <div class="flex w-full items-start gap-2">
      <input
        type="checkbox"
        id="consent"
        name="consent"
        required
        class="mt-1 h-4 w-4 rounded border-slate-400 focus:ring-zmoki-azure-500"
      />
      <label for="consent" class="font-mono text-xs">
        By checking this box, I acknowledge that I have read, understood, and agree to the <a
          href="/legal/terms/"
          class="border-b-2 border-dotted border-current text-zmoki-muted"
          target="_blank">Terms of Service</a
        > and <a
          href="/legal/privacy/"
          class="border-b-2 border-dotted border-current text-zmoki-muted"
          target="_blank">Privacy Policy</a
        >.
      </label>
    </div>

    <!-- Submit button -->
    <button
      type="submit"
      class="rounded-sm bg-zmoki-jade-500 px-4 py-2 font-mono font-medium uppercase tracking-normal text-white hover:bg-zmoki-jade-500/80"
      set:html={buttonText}
    />

    <!-- Hidden inputs -->
    <input type="text" name="email_address_check" value="" style="display: none;" />
    <input type="hidden" name="locale" value="en" />
  </section>
</form>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>

<script is:inline>
  document.getElementById("brevo-form")?.addEventListener("submit", function () {
    var email = document.getElementById("EMAIL")?.value || "";
    window.posthog?.identify(email);
    window.posthog?.capture("newsletter_form_submitted", {
      form_id: this.getAttribute("action") || "",
    });
  });
</script>
