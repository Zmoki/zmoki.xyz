---
import { getEntry } from "astro:content";
import type { CollectionEntry } from "astro:content";

export interface Props {
  slug: string;
  class: string;
}

const { slug, class: className } = Astro.props;

const resource = await getEntry("resources", slug);
if (!resource) throw new Error(`Resource not found: ${slug}`);

const href = resource.data.type === "link" ? resource.data.url : `/resources/${slug}/`;
---

<a
  href={href}
  data-resource="true"
  data-resource-slug={slug}
  data-resource-external={resource.data.type === "link" ? "true" : "false"}
  class={className}
>
  <slot set:html={resource.data.name} />
</a>

<script is:inline>
  document.querySelectorAll('a[data-resource="true"]').forEach(function (el) {
    el.addEventListener("click", function () {
      window.posthog?.capture("resource_link_clicked", {
        resource_slug: this.dataset.resourceSlug,
        is_external: this.dataset.resourceExternal === "true",
      });
    });
  });
</script>
